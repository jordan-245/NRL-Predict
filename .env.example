# NRL Predictor Configuration
# Copy this file to .env and adjust values

# Data paths (defaults work for standard project structure)
DATA_DIR=data
RAW_DIR=data/raw
PROCESSED_DIR=data/processed
FEATURES_DIR=data/features
OUTPUTS_DIR=outputs

# Scraping
RLP_BASE_URL=https://www.rugbyleagueproject.org
SCRAPE_DELAY_SECONDS=2.5
USER_AGENT=NRL-Predictor-Research/0.1 (academic project)

# Seasons
START_YEAR=2013
END_YEAR=2025

# Model training
RANDOM_SEED=42
N_OPTUNA_TRIALS=200
